# DeepSeek API key — powers in-game Agents (chat, topic emotions, scramble lines)
# Without this, guests fall back to static lines + rule-based angry/frozen
# Get one at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# PostgreSQL connection string (used by Drizzle ORM)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:password@localhost:5432/myapp
